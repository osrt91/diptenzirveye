# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
desktop.ini
*.pem
*.code-workspace

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# IDE / editor
.cursor/
.vscode/

# claude
.claude/

# kaynak (reference materials, not part of the app)
kaynak/

# typescript
*.tsbuildinfo
next-env.d.ts

# capacitor native builds
/android/app/build/
/android/.gradle/
/android/build/
/android/local.properties
/ios/App/Pods/
/ios/DerivedData/

# test results
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
